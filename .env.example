# Debug mode
VITE_DEBUG=true

# Gas settings
VITE_GAS_PRICE=300000000000
VITE_GAS_LIMIT=3000000

# Network configuration (JSON array)
VITE_SSV_NETWORKS='[...]'

# Disable network validation (dev only)
VITE_DISABLE_NETWORK_DATA_CHECK=true

# External links
VITE_LINK_SSV_DEV_DOCS=https://docs.ssv.network
VITE_EXPLORER_URL=https://explorer.ssv.network
VITE_STAKE_URL=https://stake.ssv.network

# Contract addresses
VITE_DISTRIBUTION_CONTRACT_ADDRESS=0x...

# Analytics
VITE_MIXPANEL_TOKEN=your_mixpanel_token
VITE_GOOGLE_TAG_SECRET=your_gtm_secret
VITE_SENTRY_AUTH_TOKEN=your_sentry_token

# Geolocation API keys
# Get your keys from:
# - https://ipgeolocation.io
# - https://ipregistry.co
# - https://bigdatacloud.net
VITE_IPGEO_API_KEY=your_ipgeolocation_key
VITE_IPREGISTRY_KEY=your_ipregistry_key
VITE_BIGDATACLOUD_KEY=your_bigdatacloud_key

# Feature flags (uncomment to enable)
# VITE_FAUCET_PAGE=true
# VITE_CLAIM_PAGE=true
# VITE_CAPTCHA_KEY=your_captcha_key
